# Copy this file to .env in the same folder (project root, next to index.php).
# .env is gitignored. XAMPP/Apache often does not load Windows User env vars into PHP;
# this file is loaded at startup via index.php so getenv() works.

# Public site URL (no trailing slash). CodeIgniter site_url() / base_url() use this; if unset, the app guesses
# from $_SERVER (often wrong behind proxies or for subfolders — always set on production).
# Production (Hostinger: public_html/property_list/):
# BASE_URL=https://superfinelabels.in/property_list
# Local XAMPP (folder htdocs/property):
# BASE_URL=http://localhost:8080/property
BASE_URL=

# MariaDB (matches application/config/database.php). XAMPP: 127.0.0.1 when my.ini uses bind-address=127.0.0.1
CI_DB_HOST=127.0.0.1
CI_DB_USER=root
CI_DB_PASS=
CI_DB_NAME=property
CI_DB_PORT=3306

# Browser key: Maps JavaScript API + Places API enabled in Google Cloud.
GOOGLE_MAPS_API_KEY=
