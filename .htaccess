RewriteEngine On
DirectoryIndex index.html index.php

# --- User uploads & PHP static assets (never route to CodeIgniter) ---
RewriteRule ^uploads/ - [L]
RewriteRule ^assets/ - [L]
RewriteRule ^_next/ - [L]

# --- PHP app routes (panel, admin, API) — always CodeIgniter ---
RewriteRule ^panel/?(.*)$ index.php/panel/$1 [L,QSA]
RewriteRule ^admin/?(.*)$ index.php/admin/$1 [L,QSA]
RewriteRule ^api/?(.*)$ index.php/api/$1 [L,QSA]

# --- Owner PHP panel (sidebar, site visits, property add/edit) ---
RewriteRule ^owner/auth/?$ index.php/owner/auth [L,QSA]
RewriteRule ^owner/site-visits/?(.*)$ index.php/owner/site-visits$1 [L,QSA]
RewriteRule ^owner/update-site-visit/?(.*)$ index.php/owner/update-site-visit$1 [L,QSA]
RewriteRule ^owner/dashboard/?$ index.php/owner/dashboard [L,QSA]
RewriteRule ^owner/listings/?$ index.php/owner/listings [L,QSA]
RewriteRule ^owner/enquiries/?$ index.php/owner/enquiries [L,QSA]
RewriteRule ^owner/property/save/?$ index.php/owner/property/save [L,QSA]
RewriteRule ^owner/property/add/?$ index.php/owner/property/add [L,QSA]
RewriteRule ^owner/property/edit/([0-9]+)/?$ index.php/owner/property/edit/$1 [L,QSA]

# Next.js RSC payload files must not be browsed directly
RewriteRule ^(.*/)?index\.txt/?$ $1/ [R=301,L]

# --- Legacy URLs ---
RewriteRule ^property-detail/(.+?)/?$ property/$1/ [R=301,L]

# --- Next.js static export (_next/, *.html, page folders) ---
# Real files and directories are served as-is by Apache.

# Add trailing slash when folder has index.html (Next export uses trailingSlash)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_URI} !/$
RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}/index.html -f
RewriteRule ^(.+)$ $1/ [R=301,L]

# Serve page folder index.html (e.g. /search/ -> /search/index.html)
RewriteCond %{REQUEST_URI} !/(panel|admin|api|owner)(/|$) [NC]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}index.html -f
RewriteRule ^(.+?)/?$ $1/index.html [L]

# Property detail without a pre-built static page → Next.js client shell
RewriteCond %{REQUEST_URI} !/(panel|admin|api|owner)(/|$) [NC]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^property/(?!owner/?$|tenant/?$|__build_placeholder__/?$)([^/]+)/?$ property/__build_placeholder__/index.html [L]

# Root Next homepage
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/index.html -f
RewriteRule ^$ index.html [L]

# --- CodeIgniter (API, panel, admin, uploads not matched above) ---
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php/$1 [L,QSA]
